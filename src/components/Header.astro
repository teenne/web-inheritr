---
import DarkModeToggle from './DarkModeToggle.astro';
const currentPath = Astro.url.pathname;
function isActive(href: string): boolean { if (href === '/') return currentPath === '/' || currentPath === ''; return currentPath.startsWith(href); }
interface NavLink { label: string; href: string; }
const navLinks: NavLink[] = [
  { label: 'Hjem', href: '/' },
  { label: 'Slik fungerer det', href: '/hvordan-det-fungerer' },
  { label: 'Eksempel', href: '/eksempel' },
  { label: 'Blogg', href: '/blogg' },
];
---
<header id="site-header" class="sticky top-0 z-50 bg-white transition-shadow duration-200 dark:bg-primary-950" role="banner">
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8" aria-label="Hovednavigasjon">
    <a href="/" class="font-heading text-xl font-bold text-primary-900 dark:text-white" aria-label="Arvesimulator - Ga til forsiden">Arvesimulator</a>
    <div class="hidden items-center gap-1 lg:flex">
      {navLinks.map((link) => (<a href={link.href} class:list={['rounded-md px-3 py-2 text-sm font-medium transition-colors', isActive(link.href) ? 'text-primary-700 font-semibold' : 'text-primary-600 hover:text-primary-800 dark:text-primary-300 dark:hover:text-white']} aria-current={isActive(link.href) ? 'page' : undefined}>{link.label}</a>))}
      <DarkModeToggle />
      <a href="/last-ned" class="ml-4 inline-flex items-center rounded-md bg-primary-800 px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-primary-700">Start Planleggingen</a>
    </div>
    <button id="mobile-menu-btn" type="button" class="inline-flex items-center justify-center rounded-md p-2 text-primary-700 hover:bg-primary-100 dark:text-primary-300 dark:hover:bg-primary-800 lg:hidden" aria-controls="mobile-menu" aria-expanded="false" aria-label="Apne meny">
      <svg id="hamburger-icon" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" /></svg>
      <svg id="close-icon" class="hidden h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
    </button>
  </nav>
  <div id="mobile-menu" class="hidden border-t border-primary-200 bg-white dark:border-primary-700 dark:bg-primary-950 lg:hidden" role="navigation" aria-label="Mobilnavigasjon">
    <div class="space-y-1 px-4 pb-4 pt-2">
      {navLinks.map((link) => (<a href={link.href} class:list={['block rounded-md px-3 py-2 text-base font-medium transition-colors', isActive(link.href) ? 'bg-primary-100 text-primary-800' : 'text-primary-700 hover:bg-primary-50 dark:text-primary-300']} aria-current={isActive(link.href) ? 'page' : undefined}>{link.label}</a>))}
      <div class="px-3"><DarkModeToggle /></div>
      <a href="/last-ned" class="block rounded-md bg-primary-800 px-3 py-2 text-center text-base font-semibold text-white transition-colors hover:bg-primary-700">Start Planleggingen</a>
    </div>
  </div>
</header>
<script>
  function initHeader(): void {
    const header = document.getElementById('site-header'); const menuBtn = document.getElementById('mobile-menu-btn'); const mobileMenu = document.getElementById('mobile-menu'); const hamburgerIcon = document.getElementById('hamburger-icon'); const closeIcon = document.getElementById('close-icon');
    if (!header || !menuBtn || !mobileMenu || !hamburgerIcon || !closeIcon) return;
    let ticking = false; window.addEventListener('scroll', () => { if (!ticking) { window.requestAnimationFrame(() => { if (window.scrollY > 4) header.classList.add('shadow-md'); else header.classList.remove('shadow-md'); ticking = false; }); ticking = true; } });
    let prev: HTMLElement | null = null;
    function openMenu() { prev = document.activeElement as HTMLElement; mobileMenu.classList.remove('hidden'); hamburgerIcon.classList.add('hidden'); closeIcon.classList.remove('hidden'); menuBtn.setAttribute('aria-expanded','true'); document.body.style.overflow='hidden'; }
    function closeMenu() { mobileMenu.classList.add('hidden'); hamburgerIcon.classList.remove('hidden'); closeIcon.classList.add('hidden'); menuBtn.setAttribute('aria-expanded','false'); document.body.style.overflow=''; prev?.focus(); }
    menuBtn.addEventListener('click', () => { if (!mobileMenu.classList.contains('hidden')) closeMenu(); else openMenu(); });
    document.addEventListener('keydown', (e: KeyboardEvent) => { if (e.key==='Escape' && !mobileMenu.classList.contains('hidden')) closeMenu(); });
  }
  initHeader(); document.addEventListener('astro:after-swap', initHeader);
</script>
