---
const currentYear = new Date().getFullYear();
interface FooterLink { label: string; href: string; }
const produktLinks: FooterLink[] = [
  { label: 'Slik fungerer det', href: '/hvordan-det-fungerer' },
  { label: 'Last ned', href: '/last-ned' },
  { label: 'Eksempel', href: '/eksempel' },
  { label: 'Blogg', href: '/blogg' },
];
const juridiskLinks: FooterLink[] = [
  { label: 'Personvern', href: '/personvern' },
  { label: 'Vilkar', href: '/vilkaar' },
];
---
<footer class="bg-primary-950 text-white" role="contentinfo">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
    <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
      <div>
        <h2 class="font-heading text-xl font-bold">Arvesimulator</h2>
        <p class="mt-3 text-sm leading-relaxed text-primary-300">Familier fortjener a ta arvebeslutninger basert pa fakta, ikke antakelser og folelser.</p>
      </div>
      <div>
        <h3 class="font-heading text-sm font-semibold uppercase tracking-wider text-primary-300">Produkt</h3>
        <ul class="mt-4 space-y-2" role="list">{produktLinks.map((link) => (<li><a href={link.href} class="text-sm text-primary-400 transition-colors hover:text-white">{link.label}</a></li>))}</ul>
      </div>
      <div>
        <h3 class="font-heading text-sm font-semibold uppercase tracking-wider text-primary-300">Juridisk</h3>
        <ul class="mt-4 space-y-2" role="list">{juridiskLinks.map((link) => (<li><a href={link.href} class="text-sm text-primary-400 transition-colors hover:text-white">{link.label}</a></li>))}</ul>
      </div>
    </div>
    <div class="mt-12 border-t border-primary-800 pt-8">
      <p class="text-center text-sm text-primary-500">&copy; {currentYear} Halisonworks AS. Alle rettigheter reservert.</p>
    </div>
  </div>
</footer>
